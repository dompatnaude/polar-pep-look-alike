<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin &mdash; Order Fulfillment | PepX</title>
  <link rel="stylesheet" href="styles.css">
  <style>
    /* Admin-only styles (internal tool). Does not affect storefront. */
    .admin-wrap{max-width:1200px;margin:0 auto;padding:1.5rem;}
    .admin-bar{display:flex;gap:.75rem;align-items:center;flex-wrap:wrap;margin:1rem 0;}
    .admin-bar input,.admin-bar select{padding:.5rem .6rem;border:1px solid #cbd2dc;border-radius:8px;font:inherit;}
    .admin-filters{display:grep -rn 'Failed to load account overview' *.html *.js 2>/dev/null
    flex;gap:.4rem;flex-wrap:wrap;}
    .admin-filters button{padding:.4rem .8rem;border:1px solid #cbd2dc;background:#fff;border-radius:999px;cursor:pointer;font:inherit;}
    .admin-filters button.active{background:#3f51d6;color:#fff;border-color:#3f51d6;}
    table.admin-table{width:100%;border-collapse:collapse;font-size:.92rem;}
    table.admin-table th,table.admin-table td{text-align:left;padding:.55rem .6rem;border-bottom:1px solid #e7ebf1;vertical-align:top;}
    table.admin-table th{font-weight:700;color:#475069;background:#f6f8fb;}
    table.admin-table tr:hover td{background:#f9fbfd;}
    .badge{display:inline-block;padding:.15rem .5rem;border-radius:999px;font-size:.75rem;font-weight:600;}
    .badge.gray{background:#eceff3;color:#5b6478;}
    .badge.blue{background:#e5e9fb;color:#2f3fb0;}
    .badge.green{background:#e3f4ea;color:#1c7c46;}
    .badge.amber{background:#fdf0dd;color:#8a5b12;}
    .badge.red{background:#fbe4e4;color:#a12626;}
    .link-btn{background:none;border:none;color:#3f51d6;cursor:pointer;padding:0;font:inherit;text-decoration:underline;}
    .admin-panel{border:1px solid #e0e5ee;border-radius:12px;padding:1.2rem;margin-top:1rem;background:#fff;}
    .admin-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
    .admin-grid h3{margin:.2rem 0 .5rem;}
    .admin-actions{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem;}
    .admin-actions button{padding:.5rem .9rem;border-radius:8px;border:1px solid #3f51d6;background:#3f51d6;color:#fff;cursor:pointer;font:inherit;}
    .admin-actions button.secondary{background:#fff;color:#3f51d6;}
    .muted{color:#6b7280;}
    .hidden{display:none!important;}
    .track-form{display:flex;gap:.5rem;flex-wrap:wrap;align-items:center;margin-top:.6rem;}
    .track-form input{padding:.45rem .55rem;border:1px solid #cbd2dc;border-radius:8px;font:inherit;}
  </style>
</head>
<body>
  <div class="notice-bar">Admin Console &mdash; Internal Use Only</div>
  <header><div class="container nav">
    <a href="index.html" class="logo"><span class="logo-mark"><span class="logo-word"><span class="logo-pep">pep</span><span class="logo-x">X</span></span><span class="logo-sub">admin console</span></span></a>
    <nav class="links"><a href="index.html">Storefront</a><a href="account.html">Account</a></nav>
  </div></header>

  <div class="admin-wrap">
    <h1>Order Fulfillment</h1>

    <div id="adminDenied" class="admin-panel hidden">
      <h3>Access denied</h3>
      <p class="muted">You must be signed in as an administrator to use this console.</p>
      <button class="link-btn" id="adminLoginBtn">Sign in</button>
    </div>

    <div id="adminApp" class="hidden">
      <div class="admin-bar">
        <input type="search" id="adminSearch" placeholder="Search order #, name, email, tracking&hellip;">
        <div class="admin-filters" id="adminFilters">
          <button data-filter="" class="active">All</button>
          <button data-filter="new">New orders</button>
          <button data-filter="processing">Processing</button>
          <button data-filter="shipped">Shipped</button>
          <button data-filter="completed">Completed</button>
        </div>
      </div>

      <table class="admin-table">
        <thead><tr>
          <th>Order #</th><th>Customer</th><th>Date</th><th>Total</th>
          <th>Status</th><th>Fulfillment</th><th>Tracking</th><th>Actions</th>
        </tr></thead>
        <tbody id="ordersBody"><tr><td colspan="8" class="muted">Loading&hellip;</td></tr></tbody>
      </table>

      <div id="orderDetail" class="admin-panel hidden"></div>
    </div>
  </div>

  <div class="toast" id="toast"></div>
  <script src="admin.js"></script>
</body>
</html>
