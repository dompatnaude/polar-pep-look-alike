:root{--blue:#2f43e0;--dark:#101426;--muted:#6b7280;--bg:#ffffff;--soft:#f4f6fb;}
*{margin:0;padding:0;box-sizing:border-box;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;}
body{color:var(--dark);background:var(--bg);line-height:1.5;}
a{text-decoration:none;color:inherit;}
.container{max-width:1240px;margin:0 auto;padding:0 24px;}
.bar{background:var(--blue);color:#fff;font-size:14px;font-weight:600;overflow:hidden;white-space:nowrap;padding:10px 0;}
.bar .track{display:inline-block;animation:scroll 22s linear infinite;}
.bar span{margin:0 40px;}
@keyframes scroll{from{transform:translateX(0);}to{transform:translateX(-50%);}}
header{position:sticky;top:0;background:#fff;z-index:50;border-bottom:1px solid #eee;}
.nav{display:flex;align-items:center;justify-content:space-between;padding:18px 0;}
.logo{font-weight:800;font-size:24px;letter-spacing:-0.5px;display:flex;align-items:center;gap:8px;}
.logo .ic{width:34px;height:34px;background:var(--blue);border-radius:8px;display:inline-flex;align-items:center;justify-content:center;color:#fff;font-size:18px;}
.logo .b{color:var(--blue);}
nav.menu{display:flex;gap:30px;font-weight:600;font-size:15px;}
nav.menu a:hover{color:var(--blue);}
.icons{display:flex;gap:18px;font-size:18px;color:#333;}
.hero{padding:70px 0 40px;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;}
.badge{display:inline-flex;align-items:center;gap:8px;background:var(--soft);border:1px solid #e3e8f5;color:var(--blue);font-weight:600;font-size:14px;padding:8px 16px;border-radius:999px;}
.badge .dot{width:9px;height:9px;background:#22c55e;border-radius:50%;}
.hero h1{font-size:60px;line-height:1.05;font-weight:800;letter-spacing:-1.5px;margin:24px 0;}
.hero h1 .accent{color:var(--blue);}
.hero p{color:var(--muted);font-size:18px;max-width:460px;margin-bottom:28px;}
.btns{display:flex;gap:14px;}
.btn{padding:16px 28px;border-radius:12px;font-weight:700;font-size:16px;cursor:pointer;border:none;display:inline-flex;align-items:center;gap:10px;}
.btn.primary{background:var(--blue);color:#fff;}
.btn.primary:hover{background:#2536b8;}
.btn.ghost{background:var(--soft);color:var(--dark);}
.hero-art{position:relative;height:440px;background:radial-gradient(circle at 60% 40%,#eef1fc,#fff 70%);border-radius:24px;}
.chip{position:absolute;background:#fff;box-shadow:0 12px 30px rgba(20,25,60,.12);border-radius:16px;padding:16px 20px;text-align:center;transform:rotate(-6deg);}
.chip b{display:block;font-size:18px;}
.chip small{color:var(--muted);}
.chip .price{color:var(--blue);font-weight:700;margin-top:4px;}
.c1{top:60px;left:30px;}
.c2{top:180px;left:180px;transform:rotate(3deg);}
.c3{top:110px;right:30px;transform:rotate(8deg);}
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;border-top:1px solid #eee;margin-top:40px;padding-top:36px;max-width:520px;}
.stats .n{font-size:40px;font-weight:800;color:var(--blue);}
.stats .l{color:var(--muted);font-size:15px;}
.section{padding:70px 0;}
.section h2{font-size:38px;font-weight:800;letter-spacing:-1px;text-align:center;}
.section .sub{text-align:center;color:var(--muted);margin:12px auto 46px;max-width:520px;}
.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;}
.card{border:1px solid #eee;border-radius:18px;overflow:hidden;transition:.2s;background:#fff;}
.card:hover{box-shadow:0 16px 40px rgba(20,25,60,.10);transform:translateY(-4px);}
.card .img{height:200px;background:linear-gradient(135deg,#eef1fc,#f7f8fd);}
.card .body{padding:20px;}
.tag{display:inline-block;font-size:11px;font-weight:700;letter-spacing:.5px;padding:5px 10px;border-radius:6px;background:#e8fbef;color:#16a34a;margin-bottom:12px;}
.card h3{font-size:18px;margin-bottom:8px;}
.card .from{color:var(--muted);font-size:14px;}
.card .from b{color:var(--dark);}
.calc{background:var(--soft);}
.calc-wrap{max-width:760px;margin:0 auto;background:#fff;border:1px solid #eee;border-radius:20px;padding:36px;box-shadow:0 16px 40px rgba(20,25,60,.06);}
.calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.field{display:flex;flex-direction:column;gap:8px;}
.field label{font-weight:600;font-size:14px;}
.field input{padding:14px;border:1px solid #d7dbe8;border-radius:10px;font-size:15px;}
.field input:focus{outline:none;border-color:var(--blue);}
.calc-result{margin-top:26px;background:var(--blue);color:#fff;border-radius:14px;padding:24px;text-align:center;}
.calc-result .big{font-size:34px;font-weight:800;}
.calc-result .lbl{opacity:.85;font-size:14px;margin-top:4px;}
.calc-note{color:var(--muted);font-size:13px;text-align:center;margin-top:16px;}
.tgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.tcard{border:1px solid #eee;border-radius:18px;padding:28px;background:#fff;}
.tcard .stars{color:#f5b301;font-size:18px;margin-bottom:14px;}
.tcard p{font-size:15px;color:#333;margin-bottom:18px;}
.tcard .who{font-weight:700;font-size:15px;}
.tcard .who span{display:block;color:var(--muted);font-weight:400;font-size:13px;}
.faq{max-width:820px;margin:0 auto;}
.qa{border:1px solid #eee;border-radius:12px;margin-bottom:14px;overflow:hidden;background:#fff;}
.qa .q{padding:20px 24px;font-weight:700;font-size:17px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;}
.qa .q .ico{color:var(--blue);font-size:22px;transition:.2s;}
.qa .a{max-height:0;overflow:hidden;transition:max-height .3s ease;color:var(--muted);padding:0 24px;}
.qa.open .a{max-height:200px;padding:0 24px 22px;}
.qa.open .q .ico{transform:rotate(45deg);}
.contact{background:var(--dark);color:#fff;}
.contact h2{color:#fff;}
.contact .sub{color:#aab0cc;}
.cform{max-width:640px;margin:0 auto;display:grid;gap:16px;}
.cform .row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.cform input,.cform textarea{width:100%;padding:15px;border-radius:10px;border:1px solid #2a3050;background:#191f38;color:#fff;font-size:15px;}
.cform input::placeholder,.cform textarea::placeholder{color:#8890b0;}
.cform textarea{min-height:130px;resize:vertical;}
.cform button{justify-self:start;}
.form-msg{color:#7ee0a0;font-weight:600;display:none;}
.about{background:var(--soft);}
.about .container{display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:center;}
.about h2{text-align:left;}
.about p{color:var(--muted);margin-top:18px;font-size:17px;}
.about .art{height:340px;background:radial-gradient(circle at 40% 40%,#e2e8fb,#fff);border-radius:24px;}
footer{background:var(--dark);color:#c4c9dd;padding:56px 0 30px;}
.fgrid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px;}
footer h4{color:#fff;margin-bottom:16px;font-size:16px;}
footer li{list-style:none;margin:8px 0;font-size:14px;}
footer .logo{color:#fff;margin-bottom:14px;}
.copy{border-top:1px solid #2a3050;padding-top:22px;font-size:13px;text-align:center;}
@media(max-width:900px){.hero,.about .container{grid-template-columns:1fr;}.grid{grid-template-columns:1fr 1fr;}.hero h1{font-size:44px;}nav.menu{display:none;}.fgrid,.tgrid{grid-template-columns:1fr;}.calc-grid,.cform .row{grid-template-columns:1fr;}}

/* Entry disclaimer modal */
.overlay{position:fixed;inset:0;background:rgba(16,20,38,.75);backdrop-filter:blur(4px);z-index:1000;display:flex;align-items:center;justify-content:center;padding:20px;}
.overlay.hidden{display:none;}
.modal{background:#fff;border-radius:20px;max-width:520px;width:100%;padding:40px;box-shadow:0 30px 80px rgba(0,0,0,.4);}
.modal .ml{display:inline-flex;align-items:center;gap:8px;font-weight:800;font-size:22px;margin-bottom:6px;}
.modal .ml .ic{width:34px;height:34px;background:var(--blue);border-radius:8px;display:inline-flex;align-items:center;justify-content:center;color:#fff;}
.modal h2{font-size:26px;font-weight:800;letter-spacing:-.5px;margin:14px 0 8px;text-align:left;}
.modal p.intro{color:var(--muted);font-size:15px;margin-bottom:22px;}
.check{display:flex;gap:12px;align-items:flex-start;margin-bottom:16px;font-size:15px;line-height:1.4;cursor:pointer;}
.check input{margin-top:3px;width:18px;height:18px;flex:0 0 auto;accent-color:var(--blue);cursor:pointer;}
.modal .field{margin-bottom:22px;}
.modal select{width:100%;padding:14px;border:1px solid #d7dbe8;border-radius:10px;font-size:15px;background:#fff;cursor:pointer;}
.modal select:focus{outline:none;border-color:var(--blue);}
.modal .enter{width:100%;justify-content:center;}
.modal .enter:disabled{background:#c3c8e0;cursor:not-allowed;}
.modal .decline{display:block;text-align:center;color:var(--muted);font-size:13px;margin-top:16px;cursor:pointer;background:none;border:none;width:100%;}
.modal .legal{color:var(--muted);font-size:12px;margin-top:18px;text-align:center;}
body.locked{overflow:hidden;}

/* Interactive: cart, buttons, toast */
.icons span{cursor:pointer;transition:.15s;}
.icons span:hover{color:var(--blue);}
.cart-btn{position:relative;}
.cart-count{position:absolute;top:-8px;right:-10px;background:var(--blue);color:#fff;font-size:11px;font-weight:700;min-width:18px;height:18px;border-radius:9px;display:flex;align-items:center;justify-content:center;padding:0 4px;}
.card .body{display:flex;flex-direction:column;}
.add-btn{margin-top:14px;width:100%;padding:11px;border:none;border-radius:10px;background:var(--blue);color:#fff;font-weight:700;font-size:14px;cursor:pointer;transition:.15s;}
.add-btn:hover{background:#2536b8;}
.add-btn.added{background:#16a34a;}
.drawer{position:fixed;top:0;right:0;height:100%;width:380px;max-width:90vw;background:#fff;box-shadow:-10px 0 40px rgba(0,0,0,.2);z-index:1100;transform:translateX(100%);transition:transform .3s ease;display:flex;flex-direction:column;}
.drawer.open{transform:translateX(0);}
.drawer-head{padding:22px 24px;border-bottom:1px solid #eee;display:flex;justify-content:space-between;align-items:center;}
.drawer-head h3{font-size:20px;font-weight:800;}
.drawer-head .x{cursor:pointer;font-size:24px;color:#666;background:none;border:none;}
.drawer-body{flex:1;overflow-y:auto;padding:16px 24px;}
.cart-empty{color:var(--muted);text-align:center;margin-top:40px;}
.cart-item{display:flex;gap:12px;align-items:center;padding:14px 0;border-bottom:1px solid #f0f0f0;}
.cart-item .thumb{width:52px;height:52px;border-radius:10px;background:linear-gradient(135deg,#eef1fc,#f7f8fd);flex:0 0 auto;}
.cart-item .info{flex:1;}
.cart-item .info .nm{font-weight:700;font-size:15px;}
.cart-item .info .pr{color:var(--muted);font-size:13px;}
.qty{display:flex;align-items:center;gap:8px;margin-top:6px;}
.qty button{width:24px;height:24px;border:1px solid #d7dbe8;background:#fff;border-radius:6px;cursor:pointer;font-weight:700;}
.qty span{min-width:20px;text-align:center;font-weight:600;}
.cart-item .rm{color:#db2777;background:none;border:none;cursor:pointer;font-size:13px;}
.drawer-foot{padding:22px 24px;border-top:1px solid #eee;}
.drawer-foot .tot{display:flex;justify-content:space-between;font-weight:800;font-size:19px;margin-bottom:16px;}
.drawer-foot .co{width:100%;justify-content:center;}
.backdrop{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:1050;opacity:0;pointer-events:none;transition:.3s;}
.backdrop.show{opacity:1;pointer-events:auto;}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(120px);background:var(--dark);color:#fff;padding:14px 24px;border-radius:12px;font-weight:600;z-index:1200;transition:transform .3s ease;box-shadow:0 12px 30px rgba(0,0,0,.3);}
.toast.show{transform:translateX(-50%) translateY(0);}
