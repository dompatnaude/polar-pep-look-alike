# Server
PORT=3000
NODE_ENV=development
SESSION_SECRET=replace-with-a-long-random-secret
DATABASE_PATH=./data/app.db

# Public site URL used for Stripe redirects
APP_BASE_URL=http://localhost:3000

# Optional: when frontend is hosted separately from the API
CLIENT_ORIGIN=

# Admin bootstrap (promotes this email to admin on migrate/login)
ADMIN_EMAIL=admin@example.com

# Stripe (required for checkout)
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_publishable_key

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
